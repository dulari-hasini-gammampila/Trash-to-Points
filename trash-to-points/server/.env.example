PORT=3001
NODE_ENV=development

# Postgres URI — must be a valid URL (no [placeholder] in host; encode @ # : in password as %40 %23 %3A).
# Local: create DB first, then match user/password/db name.
# Use 127.0.0.1 on Windows if localhost (::1) causes issues with Docker.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/trash_points

# Supabase: Project Settings → Database → Connection string → URI (use your real ref, region, password).
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Long random string (same value every deploy)
JWT_SECRET=change-this-to-a-long-random-string-for-production

# Vercel site origin(s), comma-separated — required for browser calls from another domain
# Example: https://your-app.vercel.app,https://your-app-git-main-yourteam.vercel.app
# Dev site (Vite default port 8000). Add every origin your browser uses so CORS passes:
#   http://localhost:8000  http://127.0.0.1:8000  http://[::1]:8000
FRONTEND_URL=http://localhost:8000,http://127.0.0.1:8000,http://[::1]:8000

# Optional: force SSL for non-Supabase Postgres
# DATABASE_SSL=true
