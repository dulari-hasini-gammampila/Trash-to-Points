# Production: your Render web service URL (no trailing slash), e.g. https://trash-to-points-api.onrender.com
VITE_API_URL=

# Optional: override where `npm run dev` proxies /api (default http://127.0.0.1:3001)
# VITE_DEV_API_PROXY=http://127.0.0.1:3001

# Optional: Vite dev server port (default 8000)
# VITE_DEV_PORT=8000

# Optional: poll dashboards this often (ms) for fresher data across users/tabs (e.g. 45000)
# VITE_DASHBOARD_POLL_MS=
